# Copy this file to `.env` and adjust
# docker compose reads `.env` automatically. The compose file also has sensible
# defaults baked in, so it runs even without a `.env`.

# --- PostgreSQL ---
POSTGRES_USER=library
POSTGRES_PASSWORD=library
POSTGRES_DB=library
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
